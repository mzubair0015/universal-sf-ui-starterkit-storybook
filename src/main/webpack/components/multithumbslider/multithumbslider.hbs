<h3>Hotel Price Range (in <abbr title="United States Dollars">USD</abbr>)</h3>
<div class="cx-slider-multithumb">
  <svg role="none" class="cx-slider-group" width="360" height="60" data-component="multithumbslider">
    <g aria-hidden="true" class="cx-rail">
      <rect height="0" width="0"></rect>
    </g>
    <g aria-hidden="true" class="cx-range">
      <rect height="0" width="0"></rect>
    </g>
    <g class="cx-minimum" role="slider" tabindex="0" aria-valuemin="0" aria-valuenow="100" aria-valuemax="250" aria-label="Hotel Minimum Price in US dollars">
      <text class="cx-value">0</text>
      <rect class="cx-focus-ring" height="0" width="0"></rect>
      <polygon class="cx-thumb" points="0,0 0,0"></polygon>
  </g>
    <g class="cx-maximum" role="slider" tabindex="0" aria-valuemin="100" aria-valuenow="250" aria-valuemax="400" aria-label="Hotel Maximum Price in US dollars">
      <text class="cx-value">0</text>
      <rect class="cx-focus-ring" height="0" width="0"></rect>
      <polygon class="cx-thumb" points="0,0 0,0"></polygon>
    </g>
  </svg>
 </div>
        