<p>Choose upgrades for your transport capsule.</p>
<div class="cx-listbox-area" data-component="multiselectrearrangablelistbox">
  <div class="cx-left-area">
    <span id="cx-ms_av_l" class="cx-listbox-label">Available upgrades:</span>
    <ul id="cx-ms_imp_list" tabindex="0" role="listbox" aria-labelledby="ms_av_l" aria-multiselectable="true">
      <li id="cx-ms_opt1" role="option" aria-selected="false">Leather seats</li>
      <li id="cx-ms_opt2" role="option" aria-selected="false">Front seat warmers</li>
      <li id="cx-ms_opt3" role="option" aria-selected="false">Rear bucket seats</li>
      <li id="cx-ms_opt4" role="option" aria-selected="false">Rear seat warmers</li>
      <li id="cx-ms_opt5" role="option" aria-selected="false">Front sun roof</li>
      <li id="cx-ms_opt6" role="option" aria-selected="false">Rear sun roof</li>
      <li id="cx-ms_opt7" role="option" aria-selected="false">Cloaking capability</li>
      <li id="cx-ms_opt8" role="option" aria-selected="false">Food synthesizer</li>
      <li id="cx-ms_opt9" role="option" aria-selected="false">Advanced waste recycling system</li>
      <li id="cx-ms_opt10" role="option" aria-selected="false">Turbo vertical take-off capability</li>
    </ul>
    <button type="button" id="cx-ex2-add" class="cx-move-right-btn" aria-keyshortcuts="Alt+ArrowRight Enter" aria-disabled="true">Add</button>
  </div>
  <div class="cx-right-area">
    <span id="cx-ms_ch_l" class="cx-listbox-label">Upgrades you have chosen:</span>
    <ul id="cx-ms_unimp_list" tabindex="0" role="listbox" aria-labelledby="ms_ch_l" aria-activedescendant="" aria-multiselectable="true">
    </ul>
    <button type="button" id="cx-ex2-delete" class="cx-move-left-btn" aria-keyshortcuts="Alt+ArrowLeft Delete" aria-disabled="true">Remove</button>
  </div>
  <div class="cx-offscreen">Last change: <span aria-live="polite" id="cx-ms_live_region"></span></div>
</div>
      