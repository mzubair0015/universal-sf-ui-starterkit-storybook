#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Get the absolute path to the .env file
ENV_FILE="$(dirname "$0")/../../.env"

# Source .env file if it exists
if [ -f "$ENV_FILE" ]; then
  echo "Loading .env file from: $ENV_FILE"
  echo "Contents of .env file:"
  cat "$ENV_FILE" | tr -d '\r'
  echo "-------------------"
  
  # Source the file
  set -a
  source "$ENV_FILE"
  set +a
  
  echo "VISUAL_TEST value after sourcing: $VISUAL_TEST"
else
  echo "No .env file found at: $ENV_FILE"
fi

# Debug: Print environment variable
echo "Current environment variable:"
echo "VISUAL_TEST=$VISUAL_TEST"

# Run lint-staged first
npx lint-staged

# Check if visual tests should be skipped (empty or false)
if [ -z "$VISUAL_TEST" ] || [ "$VISUAL_TEST" = "false" ]; then
  echo "Skipping visual tests (VISUAL_TEST=$VISUAL_TEST)"
  exit 0
fi

# Change to the ui.frontend directory
cd ui.frontend

# Function to run visual tests
run_visual_tests() {
  echo "Running visual tests (attempt $1 of $2)..."
  npm run test:visual
  return $?
}

# Run visual tests with retries
MAX_ATTEMPTS=2
attempt=1

while [ $attempt -le $MAX_ATTEMPTS ]; do
  run_visual_tests $attempt $MAX_ATTEMPTS
  if [ $? -eq 0 ]; then
    echo "✅ Visual tests passed!"
    git add .
    exit 0
  else
    if [ $attempt -eq $MAX_ATTEMPTS ]; then
      echo "❌ Visual tests failed after $MAX_ATTEMPTS attempts. Please fix the issues before committing."
      exit 1
    else
      echo "⚠️  Retrying in 2 seconds..."
      attempt=$((attempt + 1))
      sleep 2
    fi
  fi
done
